# ═══════════════════════════════════════════
# JARVIS AI Provider Configuration
# ═══════════════════════════════════════════

# Pick ONE provider: groq | openai | ollama | mock
AI_PROVIDER=groq

# ── GROQ (Recommended: Cheap + Fast) ──
# Get key: https://console.groq.com/keys (free $5/month credit)
# Pricing: ~$0.59/million tokens (90% cheaper than OpenAI)
# Models: llama-3.3-70b-versatile, mixtral-8x7b-32768, gemma2-9b-it
GROQ_API_KEY=gsk_your_key_here
AI_MODEL=llama-3.3-70b-versatile

# ── OPENAI (Most Reliable) ──
# Get key: https://platform.openai.com/api-keys
# Pricing: ~$5-10/million tokens (GPT-4o)
# Models: gpt-4o, gpt-4o-mini (cheaper, still good)
OPENAI_API_KEY=sk-your-key-here
# AI_MODEL=gpt-4o

# ── OLLAMA (Free, Runs Locally) ──
# Install: https://ollama.com/download
# Then run: ollama pull qwen2.5-coder:14b
# Zero API cost. Requires decent CPU/GPU.
# OLLAMA_HOST=http://localhost:11434
# AI_MODEL=qwen2.5-coder:14b

# ── MOCK (Free, Demo Mode) ──
# Set AI_PROVIDER=mock to test UI without any API
# Uses pre-built responses. Zero cost.

# Server port
PORT=3000